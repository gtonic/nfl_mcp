# Keep the image clean & reproducible — don't bake in local state.

# Git & CI
.git
.github
.gitignore

# Virtual envs
.venv
.venv*
venv

# Python caches / build artifacts
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache
*.egg-info
build
dist
htmlcov
.coverage
.coverage.*

# Local databases and data (must not ship in the image)
*.db
*.sqlite
*.sqlite3

# Tests & docs (not needed at runtime)
tests
docs
examples
*.md
!README.md

# Editor / OS
.vscode
.idea
.DS_Store
